# Ring auth. First run can use email/password; later runs use RING_TOKEN_PATH.
RING_EMAIL=
RING_PASSWORD=
RING_2FA_CODE=
RING_TOKEN_PATH=/data/ring-token.json

# Face recognition. FACE_PROVIDER is local, external, or none.
FACE_PROVIDER=none
FACE_API_KEY=
FACE_SIDECAR_URL=http://face-sidecar:5000
FACE_CONCURRENCY=2

# Captioning. CAPTION_PROVIDER is openai or gemini.
CAPTION_PROVIDER=
CAPTION_API_KEY=
CAPTION_MODEL=

# Webhooks. Comma-separate multiple URLs.
WEBHOOK_TARGETS=
WEBHOOK_SECRET=

# Pipeline.
DEDUP_WINDOW_MS=30000
STORE_FRAMES=false
FRAMES_DIR=

# Storage.
DB_PATH=/data/ring-ai.db

# Observability. LOG_LEVEL is debug, info, warn, or error.
LOG_LEVEL=info
